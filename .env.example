# These variables are consumed by the Express server (server/index.js).
# They are NEVER sent to the browser — secrets stay server-side.

# GitHub (optional — unauthenticated works for public repos, 60 req/h limit)
VITE_GITHUB_TOKEN=your_github_token_here
VITE_GITHUB_USERNAME=Masutayunikon

# Spotify (optional — omit all three to disable the Now Playing widget)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
VITE_SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Contact form — SMTP (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_TO=your@email.com
